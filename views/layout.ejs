<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Inventory</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">📦 Inventory</a>
        <nav class="nav">
          <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Dashboard</a>
          <a href="/categories" class="<%= currentPath.startsWith('/categories') ? 'active' : '' %>">Categories</a>
          <a href="/items" class="<%= currentPath.startsWith('/items') ? 'active' : '' %>">Items</a>
        </nav>
      </div>
    </header>

    <main class="container main-content">
      <%- body %>
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-inner">
          <p>Inventory Management App &mdash; The Odin Project</p>
          <p>Copyright &copy; 2026 Build with ❤️ by <a href="https://github.com/mooktardev" target="_blank">Mooktar Dev</a>.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
